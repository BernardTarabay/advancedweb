<%- include('partials/header', {title: 'Products', user}) %>

<div class="container">
    <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 2rem;">
        <h2>Products</h2>
        <% if (user.role === 'admin' || user.role === 'super admin') { %>
            <a href="/products/new" class="btn btn-primary">Add Product</a>
        <% } %>
    </div>
    
    <% if (locals.success) { %>
        <div class="success"><%= success %></div>
    <% } %>
    
    <% if (products.length === 0) { %>
        <div class="card">
            <p>No products found.</p>
        </div>
    <% } else { %>
        <table>
            <thead>
                <tr>
                    <th>Name</th>
                    <th>Description</th>
                    <th>Price</th>
                    <th>Quantity</th>
                    <th>Supplier</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                <% products.forEach(product => { %>
                    <tr>
                        <td><%= product.name %></td>
                        <td><%= product.description || 'N/A' %></td>
                        <td>$<%= product.price.toFixed(2) %></td>
                        <td><%= product.quantity %></td>
                        <td><%= product.supplier ? product.supplier.name : 'N/A' %></td>
                        <td>
                            <div class="actions">
                                <a href="/products/<%= product._id %>" class="btn btn-primary">View</a>
                                <% if (user.role === 'admin' || user.role === 'super admin') { %>
                                    <a href="/products/<%= product._id %>/edit" class="btn btn-success">Edit</a>
                                    <form action="/products/<%= product._id %>/delete" method="POST" style="display: inline;" onsubmit="return confirm('Are you sure?');">
                                        <button type="submit" class="btn btn-danger">Delete</button>
                                    </form>
                                <% } %>
                            </div>
                        </td>
                    </tr>
                <% }); %>
            </tbody>
        </table>
    <% } %>
</div>

<%- include('partials/footer') %>
