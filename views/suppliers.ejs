<%- include('partials/header', {title: 'Suppliers', user}) %>

<div class="container">
    <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 2rem;">
        <h2>Suppliers</h2>
        <% if (user.role === 'admin' || user.role === 'super admin') { %>
            <a href="/suppliers/new" class="btn btn-primary">Add Supplier</a>
        <% } %>
    </div>
    
    <% if (locals.success) { %>
        <div class="success"><%= success %></div>
    <% } %>
    
    <% if (suppliers.length === 0) { %>
        <div class="card">
            <p>No suppliers found.</p>
        </div>
    <% } else { %>
        <table>
            <thead>
                <tr>
                    <th>Name</th>
                    <th>Email</th>
                    <th>Phone</th>
                    <th>Address</th>
                    <th>Products</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                <% suppliers.forEach(supplier => { %>
                    <tr>
                        <td><%= supplier.name %></td>
                        <td><%= supplier.email %></td>
                        <td><%= supplier.phone || 'N/A' %></td>
                        <td><%= supplier.address || 'N/A' %></td>
                        <td><%= supplier.products ? supplier.products.length : 0 %></td>
                        <td>
                            <div class="actions">
                                <a href="/suppliers/<%= supplier._id %>" class="btn btn-primary">View</a>
                                <% if (user.role === 'admin' || user.role === 'super admin') { %>
                                    <a href="/suppliers/<%= supplier._id %>/edit" class="btn btn-success">Edit</a>
                                    <form action="/suppliers/<%= supplier._id %>/delete" method="POST" style="display: inline;" onsubmit="return confirm('Are you sure?');">
                                        <button type="submit" class="btn btn-danger">Delete</button>
                                    </form>
                                <% } %>
                            </div>
                        </td>
                    </tr>
                <% }); %>
            </tbody>
        </table>
    <% } %>
</div>

<%- include('partials/footer') %>
