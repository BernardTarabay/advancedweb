<%- include('partials/header', {title: 'User Details', user: user}) %>

<div class="container">
    <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 2rem;">
        <h2>User Details</h2>
        <div>
            <a href="/users" class="btn btn-primary">Back to Users</a>
            <% if ((user.role === 'admin' || user.role === 'super admin') && !(viewUser.role === 'super admin' && user.role !== 'super admin')) { %>
                <a href="/users/<%= viewUser._id %>/edit" class="btn btn-success">Edit</a>
            <% } %>
        </div>
    </div>
    
    <div class="card">
        <table style="box-shadow: none;">
            <tr>
                <th style="width: 200px;">Name</th>
                <td><%= viewUser.name %></td>
            </tr>
            <tr>
                <th>Email</th>
                <td><%= viewUser.email %></td>
            </tr>
            <tr>
                <th>Role</th>
                <td>
                    <span style="
                        padding: 0.25rem 0.5rem; 
                        border-radius: 4px;
                        background: <%= viewUser.role === 'super admin' ? '#c0392b' :
                                      viewUser.role === 'admin' ? '#9b59b6' : 
                                      viewUser.role === 'manager' ? '#3498db' : '#27ae60' %>;
                        color: white;
                    ">
                        <%= viewUser.role.charAt(0).toUpperCase() + viewUser.role.slice(1) %>
                    </span>
                </td>
            </tr>
            <tr>
                <th>Created At</th>
                <td><%= new Date(viewUser.createdAt).toLocaleString() %></td>
            </tr>
            <tr>
                <th>Updated At</th>
                <td><%= new Date(viewUser.updatedAt).toLocaleString() %></td>
            </tr>
        </table>
    </div>
</div>

<%- include('partials/footer') %>
