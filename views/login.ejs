<%- include('partials/header', {title: 'Login', user: null}) %>

<div class="container">
    <div class="card" style="max-width: 400px; margin: 4rem auto;">
        <h2 style="margin-bottom: 1.5rem;">Login</h2>
        
        <% if (locals.error) { %>
            <div class="error"><%= error %></div>
        <% } %>
        
        <h3>Login as User</h3>
        <form action="/auth/login" method="POST">
            <div class="form-group">
                <label for="email">Email</label>
                <input type="email" id="email" name="email" required>
            </div>
            
            <div class="form-group">
                <label for="password">Password</label>
                <input type="password" id="password" name="password" required>
            </div>
            
            <button type="submit" class="btn btn-primary" style="width: 100%;">Login as User</button>
        </form>

        <h3 style="margin-top: 2rem;">Login as Admin</h3>
        <form action="/auth/login-admin" method="POST">
            <div class="form-group">
                <label for="admin-email">Email</label>
                <input type="email" id="admin-email" name="email" required>
            </div>
            
            <div class="form-group">
                <label for="admin-password">Password</label>
                <input type="password" id="admin-password" name="password" required>
            </div>
            
            <button type="submit" class="btn btn-secondary" style="width: 100%;">Login as Admin</button>
        </form>

        <p style="margin-top: 1rem; text-align: center;">
            Don't have an account? <a href="/auth/register">Register</a>
        </p>
    </div>
</div>

<%- include('partials/footer') %>
